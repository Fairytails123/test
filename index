        async function loadBoard() {
            let loadedFromSheets = false;
            
            if (CONFIG.USE_GOOGLE_SHEETS && CONFIG.SCRIPT_URL) {
                try {
                    const response = await fetch(`${CONFIG.SCRIPT_URL}?action=load`);
                    const result = await response.json();
                    
                    if (result.success && result.data) {
                        state.today.dogs = result.data.today?.dogs || [];
                        state.today.staging = result.data.today?.staging || [];
                        state.today.vanTimes = result.data.today?.vanTimes || { BV: '07:30', DV: '08:00', SV: '08:30' };
                        state.tomorrow.dogs = result.data.tomorrow?.dogs || [];
                        state.tomorrow.staging = result.data.tomorrow?.staging || [];
                        state.tomorrow.vanTimes = result.data.tomorrow?.vanTimes || { BV: '07:30', DV: '08:00', SV: '08:30' };
                        loadedFromSheets = true;
                        console.log('✅ Loaded from Google Sheets:', {
                            today: state.today.dogs.length,
                            tomorrow: state.tomorrow.dogs.length
                        });
                    }
                } catch (error) {
                    console.error('❌ Failed to load from Google Sheets:', error);
                }
            }
            
            if (!loadedFromSheets) {
                console.warn('⚠️ Google Sheets unavailable - using localStorage (read-only mode until Sheets connects)');
                const saved = localStorage.getItem('fairyTailsStaffBoard');
                if (saved) {
                    try {
                        const data = JSON.parse(saved);
                        state.today.dogs = data.today?.dogs || [];
                        state.today.staging = data.today?.staging || [];
                        state.today.vanTimes = data.today?.vanTimes || { BV: '07:30', DV: '08:00', SV: '08:30' };
                        state.tomorrow.dogs = data.tomorrow?.dogs || [];
                        state.tomorrow.staging = data.tomorrow?.staging || [];
                        state.tomorrow.vanTimes = data.tomorrow?.vanTimes || { BV: '07:30', DV: '08:00', SV: '08:30' };
                        console.log('📦 Loaded from localStorage (temporary)');
                    } catch (e) {
                        console.error('Failed to load saved data:', e);
                    }
                }
                
                showToast('⚠️ Could not connect to Google Sheets - changes may not save', 'error');
            }
            
            populateVanTimeDropdowns();
            
            renderStaging('today');
            renderStaging('tomorrow');
            renderBoard('today');
            renderBoard('tomorrow');
            
            if (loadedFromSheets) {
                state.initialLoadComplete = true;
                console.log('✅ Initial load complete - autoSave now enabled');
            } else {
                state.initialLoadComplete = false;
                console.warn('⚠️ AutoSave DISABLED - waiting for Google Sheets connection');
                setTimeout(retryLoadFromSheets, 10000);
            }
        }
        
        async function retryLoadFromSheets() {
            if (state.initialLoadComplete) return;
            
            console.log('🔄 Retrying Google Sheets connection...');
            
            if (CONFIG.USE_GOOGLE_SHEETS && CONFIG.SCRIPT_URL) {
                try {
                    const response = await fetch(`${CONFIG.SCRIPT_URL}?action=load`);
                    const result = await response.json();
                    
                    if (result.success && result.data) {
                        const remoteToday = result.data.today?.dogs?.length || 0;
                        const remoteTomorrow = result.data.tomorrow?.dogs?.length || 0;
                        const localToday = state.today.dogs.length;
                        const localTomorrow = state.tomorrow.dogs.length;
                        
                        if (remoteToday >= localToday || remoteTomorrow >= localTomorrow) {
                            state.today.dogs = result.data.today?.dogs || [];
                            state.today.staging = result.data.today?.staging || [];
                            state.today.vanTimes = result.data.today?.vanTimes || state.today.vanTimes;
                            state.tomorrow.dogs = result.data.tomorrow?.dogs || [];
                            state.tomorrow.staging = result.data.tomorrow?.staging || [];
                            state.tomorrow.vanTimes = result.data.tomorrow?.vanTimes || state.tomorrow.vanTimes;
                            
                            populateVanTimeDropdowns();
                            renderStaging('today');
                            renderStaging('tomorrow');
                            renderBoard('today');
                            renderBoard('tomorrow');
                        }
                        
                        state.initialLoadComplete = true;
                        showToast('✅ Connected to Google Sheets', 'success');
                        console.log('✅ Reconnected to Google Sheets - autoSave now enabled');
                        return;
                    }
                } catch (error) {
                    console.error('Retry failed:', error);
                }
            }
            
            setTimeout(retryLoadFromSheets, 10000);
        }

        async function autoSave(forceLocalOnly = false) {
            if (!state.initialLoadComplete) {
                console.log('Initial load not complete - skipping save to prevent data loss');
                return;
            }
            
            const dataToSave = {
                action: 'save',
                today: { 
                    dogs: state.today.dogs, 
                    staging: state.today.staging,
                    vanTimes: state.today.vanTimes
                },
                tomorrow: { 
                    dogs: state.tomorrow.dogs, 
                    staging: state.tomorrow.staging,
                    vanTimes: state.tomorrow.vanTimes
                }
            };
            
            localStorage.setItem('fairyTailsStaffBoard', JSON.stringify(dataToSave));
            
            if (forceLocalOnly) return;
            
            if (CONFIG.USE_GOOGLE_SHEETS && CONFIG.SCRIPT_URL) {
                try {
                    const localTodayCount = state.today.dogs.length;
                    const localTomorrowCount = state.tomorrow.dogs.length;
                    const localTotal = localTodayCount + localTomorrowCount;
                    
                    console.log(`Checking remote before saving (local: Today=${localTodayCount}, Tomorrow=${localTomorrowCount})...`);
                    
                    try {
                        const response = await fetch(`${CONFIG.SCRIPT_URL}?action=load`);
                        const result = await response.json();
                        
                        if (result.success && result.data) {
                            const remoteTodayCount = result.data.today?.dogs?.length || 0;
                            const remoteTomorrowCount = result.data.tomorrow?.dogs?.length || 0;
                            const remoteTotal = remoteTodayCount + remoteTomorrowCount;

                            // Only block save if local is completely empty but remote has data
                            // (protects against page-load race, but allows normal edits/deletes)
                            if (localTotal === 0 && remoteTotal > 0) {
                                console.warn(`⚠️ BLOCKED SAVE: Local is empty but remote has ${remoteTotal} dogs`);
                                await loadBoardSilent();
                                return;
                            }
                        }
                    } catch (checkError) {
                        console.error('Could not verify remote state - skipping save to be safe:', checkError);
                        return;
                    }
                    
                    await fetch(CONFIG.SCRIPT_URL, {
                        method: 'POST',
                        mode: 'no-cors',
                        headers: {
                            'Content-Type': 'application/json',
                        },
                        body: JSON.stringify(dataToSave)
                    });
                    
                    console.log(`✅ Saved to Google Sheets (Today: ${localTodayCount}, Tomorrow: ${localTomorrowCount})`);
                    
                } catch (error) {
                    console.error('Auto-save to Google Sheets failed:', error);
                }
            }
        }

        setInterval(autoSave, 94000);
        setInterval(loadBoardSilent, 93000);

        // =====================================================
        // Transfer Dogs to Load Plan
        // =====================================================
        const LOAD_PLAN_BOX_ORDER = {
            bv: ['bv-c1', 'bv-c2', 'bv-c3', 'bv-c4', 'bv-c5', 'bv-c6', 'bv-c7',
                 'bv-b1', 'bv-b2', 'bv-b3', 'bv-b4', 'bv-b5', 'bv-b6', 'bv-b7', 'bv-b8'],
            sv: ['sv-c1', 'sv-c2', 'sv-c3', 'sv-c4', 'sv-c5',
                 'sv-b1', 'sv-b2', 'sv-b3', 'sv-b4', 'sv-b5'],
            dv: ['dv-l1', 'dv-l2', 'dv-m1', 'dv-m2', 'dv-m3', 'dv-m-xl', 'dv-r1', 'dv-r2']
        };

        const LOAD_PLAN_STORAGE_PREFIX = 'van_v5_';
        const LOAD_PLAN_SCRIPT_URL = 'https://script.google.com/macros/s/AKfycbxUeIiIJQZZeoo3aXHDdqVZNNqFKLhWhi_WhPVb6GUIvkMlfNxTKsOXyCTGdvAEsMLC/exec';

        async function transferToLoadPlan() {
            const tab = state.currentTab;
            const dogs = state[tab].dogs;

            const vpField = tab === 'today' ? 'vpPM' : 'vpAM';
            const planId = tab === 'today' ? 'PM' : 'NEXT_AM';
            const planLabel = tab === 'today' ? 'PM' : 'Next Day AM';
            const storageKey = LOAD_PLAN_STORAGE_PREFIX + planId;

            const vanDogs = { bv: [], sv: [], dv: [] };
            const trayDogs = [];
            let skippedCount = 0;

            dogs.forEach(dog => {
                if (!dog.name || !dog.name.trim()) {
                    skippedCount++;
                    return;
                }

                const serviceType = dog.serviceType || '';

                // Boarding School always excluded from load plan
                if (serviceType === 'Boarding School') {
                    skippedCount++;
                    return;
                }

                // Half Day AM excluded from Today's PM plan (they leave at noon),
                // but included in Tomorrow's Next Day AM plan (they need morning pickup)
                if (serviceType === 'Half Day AM' && tab === 'today') {
                    skippedCount++;
                    return;
                }

                const vanAssignment = dog[vpField] || '';

                if (vanAssignment === 'BV') {
                    vanDogs.bv.push(dog.name);
                } else if (vanAssignment === 'SV') {
                    vanDogs.sv.push(dog.name);
                } else if (vanAssignment === 'DV') {
                    vanDogs.dv.push(dog.name);
                } else if (vanAssignment === 'V') {
                    trayDogs.push(dog.name);
                } else {
                    skippedCount++;
                }
            });

            const vanTotal = vanDogs.bv.length + vanDogs.sv.length + vanDogs.dv.length;
            const totalToTransfer = vanTotal + trayDogs.length;

            if (totalToTransfer === 0) {
                showToast('No dogs to transfer to Load Plan', 'error');
                return;
            }

            const confirmMsg = 
                `Transfer ${totalToTransfer} dogs to ${planLabel} Load Plan?\n\n` +
                `This will CLEAR the existing ${planLabel} plan.\n\n` +
                `🚐 BV: ${vanDogs.bv.length}\n` +
                `🚗 SV: ${vanDogs.sv.length}\n` +
                `📦 DV: ${vanDogs.dv.length}\n` +
                `📋 Tray: ${trayDogs.length}\n` +
                `⏭️ Skipped: ${skippedCount}`;

            if (!confirm(confirmMsg)) return;

            const loadPlanState = {
                tiles: {},
                placements: {},
                stops: {},
                departures: {}
            };

            let tileCounter = 0;
            function generateLoadPlanTileId() {
                tileCounter++;
                return 't_lp_' + Date.now() + '_' + tileCounter + '_' + Math.random().toString(36).substr(2, 4);
            }

            function fillVanBoxes(dogNames, boxes) {
                const tileIds = dogNames.map(name => {
                    const id = generateLoadPlanTileId();
                    loadPlanState.tiles[id] = { id: id, text: name };
                    return id;
                });

                let dogIndex = 0;
                for (let i = 0; i < boxes.length && dogIndex < tileIds.length; i++) {
                    if (!loadPlanState.placements[boxes[i]]) {
                        loadPlanState.placements[boxes[i]] = [];
                    }
                    loadPlanState.placements[boxes[i]].push(tileIds[dogIndex]);
                    dogIndex++;
                }

                for (let i = 0; i < boxes.length && dogIndex < tileIds.length; i++) {
                    if (!loadPlanState.placements[boxes[i]]) {
                        loadPlanState.placements[boxes[i]] = [];
                    }
                    if (loadPlanState.placements[boxes[i]].length < 2) {
                        loadPlanState.placements[boxes[i]].push(tileIds[dogIndex]);
                        dogIndex++;
                    }
                }

                while (dogIndex < tileIds.length) {
                    console.warn(`⚠️ Van overflow: ${dogNames[dogIndex]} sent to tray`);
                    dogIndex++;
                }
            }

            fillVanBoxes(vanDogs.bv, LOAD_PLAN_BOX_ORDER.bv);
            fillVanBoxes(vanDogs.sv, LOAD_PLAN_BOX_ORDER.sv);
            fillVanBoxes(vanDogs.dv, LOAD_PLAN_BOX_ORDER.dv);

            trayDogs.forEach(name => {
                const id = generateLoadPlanTileId();
                loadPlanState.tiles[id] = { id: id, text: name };
            });

            try {
                localStorage.setItem(storageKey, JSON.stringify(loadPlanState));
                console.log(`📦 Load Plan written to localStorage key: ${storageKey}`);

                showToast(`☁️ Uploading ${totalToTransfer} dogs to cloud...`, 'info');

                const response = await fetch(LOAD_PLAN_SCRIPT_URL, {
                    method: 'POST',
                    body: JSON.stringify({
                        action: 'savePlan',
                        planId: planId,
                        state: loadPlanState
                    }),
                    redirect: 'follow'
                });

                const resultText = await response.text();
                console.log('☁️ Load Plan cloud response:', resultText);

                showToast(`🚐 ${totalToTransfer} dogs → ${planLabel} Load Plan (synced to cloud)`, 'success');
                console.log(`✅ Load Plan cloud sync complete for ${planId}`);
                console.log(`   BV: ${vanDogs.bv.length}, SV: ${vanDogs.sv.length}, DV: ${vanDogs.dv.length}, Tray: ${trayDogs.length}`);

            } catch (e) {
                console.error('❌ Failed to sync Load Plan to cloud:', e);
                showToast(`⚠️ ${totalToTransfer} dogs saved locally but cloud sync failed — open Load Plan on this device or retry`, 'error');
            }
        }

        // =====================
        // Initialization
        // =====================
        function init() {
            updateTime();
            setInterval(updateTime, 1000);
            loadBoard();
        }

        init();
    </script>
</body>
</html>
