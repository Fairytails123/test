                            title="Pick Up">
                        <option value="">Pick Up...</option>
                        ${pickupOptions.map(opt => `<option value="${opt}" ${pickup === opt ? 'selected' : ''}>${opt}</option>`).join('')}
                    </select>
                    
                    <select class="grooming-select grooming-dropoff ${dropoff ? 'has-value' : ''}" 
